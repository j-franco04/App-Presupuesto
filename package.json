{
  "name": "presupuestos-app",
  "version": "1.0.0",
  "description": "Sistema de Presupuestos AB TECHNOLOGY BY",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "Javier Franco",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.1",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.abtechnology.presupuestos",
    "productName": "AB Technology Presupuestos",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "NLOGO.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AB Technology"
    },
    "files": [
      "index.html",
      "main.js",
      "NLOGO.png",
      "package.json"
    ],
    "extraResources": [
      "NLOGO.png"
    ]
  }
}