{
  "name": "presupuestos-app",
  "version": "1.0.0",
  "description": "Sistema de Presupuestos AB TECHNOLOGY BY",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Javier Franco",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.4.1",
    "pdfkit": "^0.18.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "electron-packager": "latest"
  },
  "build": {
    "appId": "com.abtechnology.presupuestos",
    "productName": "AB Technology Presupuestos",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icono.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AB Technology"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      "NLOGO.png"
    ]
  }
}
